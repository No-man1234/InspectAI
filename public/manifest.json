{
  "manifest_version": 3,
  "name": "AI Website Inspector",
  "version": "1.0.0",
  "description": "Production-ready AI-powered Chrome Extension for deep webpage UX, architectural, accessibility, and design analysis.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Website Inspector"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pageInspector.js", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
